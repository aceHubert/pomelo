{
  "collection": "@nestjs/schematics",
  "sourceRoot": "servers/infrastructure-service/src",
  "monorepo": true,
  "root": "servers/infrastructure-service",
  "compilerOptions": {
    "deleteOutDir": false,
    "webpack": false,
    "webpackConfigPath": "servers/infrastructure-service/webpack-hmr.config.js",
    "tsConfigPath": "servers/infrastructure-service/tsconfig.json"
  },
  "projects": {
    "identity-server": {
      "type": "application",
      "root": "servers/identity-server",
      "entryFile": "src/main",
      "sourceRoot": "servers/identity-server",
      "compilerOptions": {
        "webpackConfigPath": "servers/identity-server/webpack-hmr.config.js",
        "tsConfigPath": "servers/identity-server/tsconfig.json",
        "assets": [
          {
            "include": "public",
            "exclude": "public/**/*.less",
            "outDir": "dist/servers/identity-server/",
            "watchAssets": true
          },
          {
            "include": "views",
            "outDir": "dist/servers/identity-server/",
            "watchAssets": true
          },
          {
            "include": ".env?(.*)",
            "outDir": "dist/servers/identity-server/",
            "watchAssets": true
          },
          {
            "include": "**/*.gql",
            "outDir": "dist/servers/identity-server/",
            "watchAssets": true
          },
          {
            "include": "../content",
            "exclude": "uploads/**/*",
            "outDir": "dist/servers/content",
            "watchAssets": true
          },
          {
            "include": "../conf",
            "outDir": "dist/servers/conf",
            "watchAssets": true
          }
        ],
        "watchAssets": true,
        "plugins": [
          {
            "name": "@nestjs/swagger",
            "options": {
              "dtoFileNameSuffix": [".dto.ts", ".resp.ts"],
              "controllerKeyOfComment": "summary",
              "classValidatorShim": true,
              "introspectComments": true
            }
          },
          {
            "name": "@nestjs/graphql",
            "options": {
              "typeFileNameSuffix": [".input.ts", ".args.ts", ".model.ts"],
              "introspectComments": true
            }
          }
        ]
      }
    },
    "infrastructure-service": {
      "type": "application",
      "root": "servers/infrastructure-service",
      "entryFile": "src/main",
      "sourceRoot": "servers/infrastructure-service",
      "compilerOptions": {
        "webpackConfigPath": "servers/infrastructure-service/webpack-hmr.config.js",
        "tsConfigPath": "servers/infrastructure-service/tsconfig.json",
        "assets": [
          {
            "include": ".env?(.*)",
            "outDir": "dist/servers/infrastructure-service/",
            "watchAssets": true
          },
          {
            "include": "../content",
            "exclude": "uploads/**/*",
            "outDir": "dist/servers/content",
            "watchAssets": true
          },
          {
            "include": "../conf",
            "outDir": "dist/servers/conf",
            "watchAssets": true
          }
        ],
        "watchAssets": true,
        "plugins": [
          {
            "name": "@nestjs/swagger",
            "options": {
              "dtoFileNameSuffix": [".dto.ts", ".resp.ts"],
              "controllerKeyOfComment": "summary",
              "classValidatorShim": true,
              "introspectComments": true
            }
          },
          {
            "name": "@nestjs/graphql",
            "options": {
              "typeFileNameSuffix": [".input.ts", ".args.ts", ".model.ts"],
              "introspectComments": true
            }
          }
        ]
      }
    },
    "infrastructure-bff": {
      "type": "application",
      "root": "servers/infrastructure-bff",
      "entryFile": "src/main",
      "sourceRoot": "servers/infrastructure-bff",
      "compilerOptions": {
        "webpackConfigPath": "servers/infrastructure-bff/webpack-hmr.config.js",
        "tsConfigPath": "servers/infrastructure-bff/tsconfig.json",
        "assets": [
          {
            "include": ".env?(.*)",
            "outDir": "dist/servers/infrastructure-bff/",
            "watchAssets": true
          },
          {
            "include": "../content",
            "exclude": "uploads/**/*",
            "outDir": "dist/servers/content",
            "watchAssets": true
          },
          {
            "include": "../conf",
            "outDir": "dist/servers/conf",
            "watchAssets": true
          }
        ],
        "watchAssets": true,
        "plugins": [
          {
            "name": "@nestjs/swagger",
            "options": {
              "dtoFileNameSuffix": [".dto.ts", ".resp.ts"],
              "controllerKeyOfComment": "summary",
              "classValidatorShim": true,
              "introspectComments": true
            }
          },
          {
            "name": "@nestjs/graphql",
            "options": {
              "typeFileNameSuffix": [".input.ts", ".args.ts", ".model.ts"],
              "introspectComments": true
            }
          }
        ]
      }
    },
    "nestjs-oidc": {
      "type": "library",
      "root": "packages/nestjs-oidc",
      "entryFile": "src/index",
      "sourceRoot": "packages/nestjs-oidc",
      "compilerOptions": {
        "tsConfigPath": "packages/nestjs-oidc/tsconfig.json"
      }
    },
    "nest-authorization": {
      "type": "library",
      "root": "packages/nest-authorization",
      "entryFile": "src/index",
      "sourceRoot": "packages/nest-authorization",
      "compilerOptions": {
        "tsConfigPath": "packages/nest-authorization/tsconfig.json"
      }
    },
    "nest-ram-authorization": {
      "type": "library",
      "root": "packages/nest-ram-authorization",
      "entryFile": "src/index",
      "sourceRoot": "packages/nest-ram-authorization",
      "compilerOptions": {
        "tsConfigPath": "packages/nest-ram-authorization/tsconfig.json"
      }
    },
    "nest-log4js": {
      "type": "library",
      "root": "packages/nest-log4js",
      "entryFile": "src/index",
      "sourceRoot": "packages/nest-log4js",
      "compilerOptions": {
        "tsConfigPath": "packages/nest-log4js/tsconfig.json"
      }
    },
    "pomelo-shared": {
      "type": "library",
      "root": "packages/pomelo-shared",
      "entryFile": "src/index",
      "sourceRoot": "packages/pomelo-shared",
      "compilerOptions": {
        "tsConfigPath": "packages/pomelo-shared/tsconfig.json"
      }
    }
  }
}
